{
  "name": "n8watch",
  "version": "1.0.0",
  "description": "Real-time IP monitoring system",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node server/index.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop n8watch",
    "pm2:restart": "pm2 restart n8watch",
    "pm2:reload": "pm2 reload n8watch",
    "pm2:logs": "pm2 logs n8watch",
    "pm2:status": "pm2 status",
    "pm2:save": "pm2 save",
    "pm2:startup": "pm2 startup",
    "electron": "electron electron/main.js",
    "electron:rebuild": "electron-rebuild -f -w better-sqlite3",
    "electron:build": "npm run electron:rebuild && electron-builder",
    "electron:build:win": "npm run electron:rebuild && electron-builder --win",
    "electron:build:mac": "npm run electron:rebuild && electron-builder --mac",
    "electron:build:linux": "npm run electron:rebuild && electron-builder --linux",
    "db:flush": "node scripts/flush-data.js",
    "db:flush:all": "node scripts/flush-data.js --all",
    "db:nuke": "node scripts/nuke-db.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "express-rate-limit": "^8.3.1",
    "js-yaml": "^4.1.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.3",
    "ping": "^0.4.4",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.n8watch.app",
    "productName": "n8watch",
    "copyright": "Copyright © 2024 n8watch contributors",
    "files": [
      "server/**/*",
      "electron/**/*",
      "client/dist/**/*",
      "config.example.yaml",
      "ecosystem.config.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "config.example.yaml",
        "to": "config.example.yaml"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/icons/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "electron/icons/icon.icns"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/icons/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "n8watch"
    },
    "directories": {
      "output": "dist-electron"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "node_modules/bindings/**/*"
    ]
  }
}
