[Unit]
Description=FortiGate Monitor API
After=network.target forti-poller.service

[Service]
Type=simple
User=forti-monitor
Group=forti-monitor
WorkingDirectory=/opt/forti-monitor
EnvironmentFile=-/etc/forti-monitor/env
ExecStart=/opt/forti-monitor/venv/bin/uvicorn api.main:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=forti-api

[Install]
WantedBy=multi-user.target
